<Window
    x:Class="Sirstrap.UI.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:Sirstrap.UI.Behaviors"
    xmlns:common="using:Sirstrap.UI.Views.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sirstrap.UI.Models"
    xmlns:vm="using:Sirstrap.UI.ViewModels"
    MaxHeight="250"
    mc:Ignorable="d"
    CanResize="False"
    ExtendClientAreaToDecorationsHint="True"
    Icon="/Assets/favicon.ico"
    SizeToContent="WidthAndHeight"
    Title=""
    TransparencyLevelHint="AcrylicBlur"
    WindowStartupLocation="CenterOwner"
    x:DataType="vm:MainWindowViewModel">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <common:WavyBackground
            Grid.Row="0"
            Grid.RowSpan="3"
            Margin="-5"
            IsHitTestVisible="False" />
        <TextBlock
            Grid.Row="0"
            Margin="0,4,0,9"
            HorizontalAlignment="Center"
            FontSize="10"
            Text="Sirstrap" />
        <Border
            Grid.Row="1"
            Background="#80212830"
            BoxShadow="0 0 10 0 #212830"
            CornerRadius="5"
            Padding="5">
            <Grid Width="1000">
                <ScrollViewer
                    behaviors:AutoScrollToEnd.IsEnabled="True"
                    behaviors:ScrollFade.IsEnabled="True"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <SelectableTextBlock
                        Margin="0,0,15,47"
                        FontSize="10"
                        IsVisible="{Binding SessionLog, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Text="{Binding SessionLog}"
                        TextWrapping="Wrap" />
                </ScrollViewer>
                <StackPanel
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal"
                    Spacing="5">
                    <Border
                        Background="#2a323c"
                        BoxShadow="0 0 10 0 #212830"
                        CornerRadius="999"
                        Padding="5">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            behaviors:StaggeredReveal.IsEnabled="True"
                            Orientation="Horizontal"
                            Spacing="5">
                            <Button
                                Width="32"
                                Height="32"
                                Classes="hover-lift"
                                Command="{Binding OpenGitHubProfileCommand}"
                                CornerRadius="999"
                                ToolTip.Tip="Open GitHub profile">
                                <Panel Width="32" Height="32">
                                    <Border
                                        Background="#33ffffff"
                                        CornerRadius="999"
                                        IsVisible="{Binding ProfileImage, Converter={x:Static ObjectConverters.IsNull}}">
                                        <Border.Styles>
                                            <Style Selector="Border">
                                                <Style.Animations>
                                                    <Animation
                                                        Duration="0:0:1"
                                                        Easing="SineEaseInOut"
                                                        IterationCount="Infinite"
                                                        PlaybackDirection="Alternate">
                                                        <KeyFrame Cue="0%">
                                                            <Setter Property="Opacity" Value="1" />
                                                        </KeyFrame>
                                                        <KeyFrame Cue="100%">
                                                            <Setter Property="Opacity" Value="0.3" />
                                                        </KeyFrame>
                                                    </Animation>
                                                </Style.Animations>
                                            </Style>
                                        </Border.Styles>
                                    </Border>
                                    <Border
                                        ClipToBounds="True"
                                        CornerRadius="999"
                                        IsVisible="{Binding ProfileImage, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <Image RenderOptions.BitmapInterpolationMode="HighQuality" Source="{Binding ProfileImage}" />
                                    </Border>
                                </Panel>
                            </Button>
                            <Border
                                Width="1"
                                Height="20"
                                VerticalAlignment="Center"
                                Background="#33ffffff" />
                            <Button
                                Width="32"
                                Height="32"
                                Classes="hover-lift"
                                Command="{Binding OpenGitHubCommand}"
                                CornerRadius="999"
                                ToolTip.Tip="Open GitHub repository">
                                <Panel Width="32" Height="32">
                                    <Border
                                        Background="#33ffffff"
                                        CornerRadius="999"
                                        IsVisible="{Binding LogoImage, Converter={x:Static ObjectConverters.IsNull}}">
                                        <Border.Styles>
                                            <Style Selector="Border">
                                                <Style.Animations>
                                                    <Animation
                                                        Duration="0:0:1"
                                                        Easing="SineEaseInOut"
                                                        IterationCount="Infinite"
                                                        PlaybackDirection="Alternate">
                                                        <KeyFrame Cue="0%">
                                                            <Setter Property="Opacity" Value="1" />
                                                        </KeyFrame>
                                                        <KeyFrame Cue="100%">
                                                            <Setter Property="Opacity" Value="0.3" />
                                                        </KeyFrame>
                                                    </Animation>
                                                </Style.Animations>
                                            </Style>
                                        </Border.Styles>
                                    </Border>
                                    <Border
                                        ClipToBounds="True"
                                        CornerRadius="999"
                                        IsVisible="{Binding LogoImage, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <Image RenderOptions.BitmapInterpolationMode="HighQuality" Source="{Binding LogoImage}" />
                                    </Border>
                                </Panel>
                            </Button>
                        </StackPanel>
                    </Border>
                    <Border
                        Background="#2a323c"
                        BoxShadow="0 0 10 0 #212830"
                        CornerRadius="999"
                        IsVisible="{Binding SirHurtUser, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Padding="5">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            behaviors:StaggeredReveal.IsEnabled="True"
                            Orientation="Horizontal"
                            Spacing="5">
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Text="{Binding SirHurtUser}" />
                            <Border
                                Width="1"
                                Height="20"
                                VerticalAlignment="Center"
                                Background="#33ffffff" />
                            <Button
                                Width="32"
                                Height="32"
                                Classes="hover-lift"
                                Command="{Binding LogoutCommand}"
                                CornerRadius="999"
                                ToolTip.Tip="Logout from SirHurt">
                                <Image
                                    Margin="0"
                                    RenderOptions.BitmapInterpolationMode="HighQuality"
                                    Source="avares://Sirstrap/Assets/logout.png" />
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border
                    Margin="0,0,15,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="#2a323c"
                    BoxShadow="0 0 10 0 #212830"
                    CornerRadius="999"
                    Padding="5">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        behaviors:StaggeredReveal.IsEnabled="True"
                        Orientation="Horizontal"
                        Spacing="5">
                        <Button
                            Width="32"
                            Height="32"
                            Classes="hover-lift"
                            Command="{Binding OpenSettingsCommand}"
                            CornerRadius="999"
                            ToolTip.Tip="Open settings">
                            <Image
                                Margin="0"
                                RenderOptions.BitmapInterpolationMode="HighQuality"
                                Source="avares://Sirstrap/Assets/settings.png" />
                        </Button>
                        <SplitButton
                            Width="160"
                            Height="32"
                            Classes="hover-lift"
                            Command="{Binding RunCommand}"
                            CornerRadius="16"
                            IsEnabled="{Binding ShowLaunchButton}"
                            ToolTip.Tip="Launch Roblox">
                            <SplitButton.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Offset="0" Color="#736abf6a" />
                                    <GradientStop Offset="1" Color="#266abf6a" />
                                </LinearGradientBrush>
                            </SplitButton.Background>
                            <Image
                                Margin="0"
                                RenderOptions.BitmapInterpolationMode="HighQuality"
                                Source="avares://Sirstrap/Assets/run.png" />
                            <SplitButton.Flyout>
                                <Flyout Placement="TopEdgeAlignedRight">
                                    <ListBox
                                        Width="320"
                                        MaxHeight="360"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ItemsSource="{Binding VersionSources}"
                                        SelectedItem="{Binding SelectedVersionSourceMain, Mode=TwoWay}">
                                        <ListBox.Styles>
                                            <Style Selector="ListBoxItem">
                                                <Setter Property="MinHeight" Value="0" />
                                                <Setter Property="Height" Value="32" />
                                                <Setter Property="Margin" Value="0,1" />
                                                <Setter Property="Padding" Value="10,0" />
                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                                <Setter Property="CornerRadius" Value="999" />
                                            </Style>
                                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                <Setter Property="Background" Value="#22ffffff" />
                                            </Style>
                                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                                <Setter Property="Background" Value="#33ffffff" />
                                            </Style>
                                        </ListBox.Styles>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:VersionSourceOption">
                                                <TextBlock
                                                    Text="{Binding Display}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Flyout>
                            </SplitButton.Flyout>
                        </SplitButton>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <TextBlock
            Grid.Row="2"
            Margin="0,9,0,4"
            HorizontalAlignment="Center"
            FontSize="10"
            Text="{Binding CurrentFullVersion}" />
    </Grid>
</Window>
