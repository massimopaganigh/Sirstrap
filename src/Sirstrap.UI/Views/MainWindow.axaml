<Window
    x:Class="Sirstrap.UI.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:Sirstrap.UI.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Sirstrap.UI.ViewModels"
    MaxHeight="250"
    mc:Ignorable="d"
    CanResize="False"
    ExtendClientAreaToDecorationsHint="True"
    Icon="/Assets/favicon.ico"
    SizeToContent="WidthAndHeight"
    Title=""
    TransparencyLevelHint="AcrylicBlur"
    WindowStartupLocation="CenterOwner"
    x:DataType="vm:MainWindowViewModel">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0"
            Margin="0,4,0,9"
            HorizontalAlignment="Center"
            FontSize="10"
            Text="Sirstrap" />
        <Border
            Grid.Row="1"
            Background="#212830"
            BoxShadow="0 0 10 0 #212830"
            CornerRadius="5"
            Padding="5">
            <Grid Width="750">
                <ScrollViewer
                    behaviors:AutoScrollToEnd.IsEnabled="True"
                    behaviors:ScrollFade.IsEnabled="True"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <SelectableTextBlock
                        Margin="0,0,15,47"
                        FontSize="10"
                        Text="{Binding SessionLog}"
                        TextWrapping="Wrap" />
                </ScrollViewer>
                <Border
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Background="#2a323c"
                    BoxShadow="0 0 10 0 #212830"
                    CornerRadius="999"
                    Padding="5">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        behaviors:StaggeredReveal.IsEnabled="True"
                        Orientation="Horizontal"
                        Spacing="5">
                        <Button
                            Width="32"
                            Height="32"
                            BorderThickness="0"
                            Classes="hover-lift"
                            Command="{Binding OpenGitHubProfileCommand}"
                            CornerRadius="999"
                            ToolTip.Tip="Open GitHub profile">
                            <Panel Width="32" Height="32">
                                <Border
                                    Background="#33ffffff"
                                    CornerRadius="999"
                                    IsVisible="{Binding ProfileImage, Converter={x:Static ObjectConverters.IsNull}}">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation
                                                    Duration="0:0:1"
                                                    Easing="SineEaseInOut"
                                                    IterationCount="Infinite"
                                                    PlaybackDirection="Alternate">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="Opacity" Value="0.3" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                </Border>
                                <Border
                                    ClipToBounds="True"
                                    CornerRadius="999"
                                    IsVisible="{Binding ProfileImage, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <Image RenderOptions.BitmapInterpolationMode="HighQuality" Source="{Binding ProfileImage}" />
                                </Border>
                            </Panel>
                        </Button>
                        <Border
                            Width="1"
                            Height="20"
                            VerticalAlignment="Center"
                            Background="#33ffffff" />
                        <Button
                            Width="32"
                            Height="32"
                            BorderThickness="0"
                            Classes="hover-lift"
                            Command="{Binding OpenGitHubCommand}"
                            CornerRadius="999"
                            ToolTip.Tip="Open GitHub repository">
                            <Panel Width="32" Height="32">
                                <Border
                                    Background="#33ffffff"
                                    CornerRadius="999"
                                    IsVisible="{Binding LogoImage, Converter={x:Static ObjectConverters.IsNull}}">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation
                                                    Duration="0:0:1"
                                                    Easing="SineEaseInOut"
                                                    IterationCount="Infinite"
                                                    PlaybackDirection="Alternate">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="Opacity" Value="0.3" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                </Border>
                                <Border
                                    ClipToBounds="True"
                                    CornerRadius="999"
                                    IsVisible="{Binding LogoImage, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <Image RenderOptions.BitmapInterpolationMode="HighQuality" Source="{Binding LogoImage}" />
                                </Border>
                            </Panel>
                        </Button>
                    </StackPanel>
                </Border>
                <Border
                    Margin="0,0,15,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="#2a323c"
                    BoxShadow="0 0 10 0 #212830"
                    CornerRadius="999"
                    Padding="5">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        behaviors:StaggeredReveal.IsEnabled="True"
                        Orientation="Horizontal"
                        Spacing="5">
                        <Button
                            Width="32"
                            Height="32"
                            BorderThickness="0"
                            Classes="hover-lift"
                            Command="{Binding OpenSettingsCommand}"
                            CornerRadius="999"
                            ToolTip.Tip="Open settings">
                            <Image
                                Margin="0"
                                RenderOptions.BitmapInterpolationMode="HighQuality"
                                Source="avares://Sirstrap/Assets/settings.png" />
                        </Button>
                        <SplitButton
                            Width="160"
                            Height="32"
                            Background="#4d6abf6a"
                            BorderThickness="0"
                            Classes="hover-lift"
                            Command="{Binding RunCommand}"
                            CornerRadius="999"
                            IsEnabled="{Binding ShowLaunchButton}"
                            ToolTip.Tip="Launch Roblox (use the arrow to pick the version source)">
                            <Image
                                Margin="0"
                                RenderOptions.BitmapInterpolationMode="HighQuality"
                                Source="avares://Sirstrap/Assets/run.png" />
                            <SplitButton.Flyout>
                                <Flyout Placement="TopEdgeAlignedRight">
                                    <ListBox
                                        Width="320"
                                        MaxHeight="360"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ItemsSource="{Binding VersionSources}"
                                        SelectedItem="{Binding SelectedVersionSourceMain, Mode=TwoWay}"
                                        x:CompileBindings="False">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Flyout>
                            </SplitButton.Flyout>
                        </SplitButton>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <TextBlock
            Grid.Row="2"
            Margin="0,9,0,4"
            HorizontalAlignment="Center"
            FontSize="10"
            Text="{Binding CurrentFullVersion}" />
    </Grid>
</Window>
